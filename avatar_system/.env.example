# Copy to .env and adjust

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1

# Port für den Webserver
PORT=8000

# Pfad zu deinem Video-Ordner auf dem Host (read-only gemountet)
VIDEO_FOLDER=/path/to/your/training/videos

# Redis (normalerweise nicht ändern)
REDIS_URL=redis://redis:6379/0
